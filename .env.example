# Nuxt 3 Environment Variables
# Copy this file to .env and fill in your values

# Site URL (for production)
# NUXT_PUBLIC_SITE_URL=https://goldenhomedb.vn

# Google Analytics ID (optional)
# NUXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Contact Form Email (for backend integration)
# CONTACT_EMAIL=info@goldenhomedb.vn

# API URL (if using external API)
# NUXT_PUBLIC_API_URL=https://api.goldenhomedb.vn
